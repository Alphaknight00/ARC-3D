# ═══════════════════════════════════════════════════════════════
# ARC3D™ Database Server — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# MongoDB connection string
# Local:   mongodb://localhost:27017/arc3d
# Atlas:   mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/arc3d
MONGODB_URI=mongodb://localhost:27017/arc3d

# JWT secret — use a long random string in production
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# JWT token expiry (e.g. 7d, 24h, 3600)
JWT_EXPIRES_IN=7d

# Server port
PORT=3000

# Allowed origins for CORS (comma-separated)
# In production, set to your actual domain
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://hsan-studios.com,https://alphaknight00.github.io,https://alphaknight00.github.io/ARC-3D

# bcrypt salt rounds (10-12 is recommended)
BCRYPT_SALT_ROUNDS=12
